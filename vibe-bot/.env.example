# ===========================================
# GitHub App Configuration
# ===========================================
# Récupère ces valeurs depuis : https://github.com/settings/apps

# ID de l'application GitHub
GITHUB_APP_ID=your_github_app_id_here

# Clé privée de l'application (format PEM)
# Exemple : -----BEGIN RSA PRIVATE KEY-----
# MIIEpAIBAAKCAQEA... (à copier depuis GitHub)
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"

# Secret du webhook (généré lors de la création de l'app)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# Mistral AI Configuration
# ===========================================
# Récupère ta clé API depuis : https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Modèle à utiliser (par défaut : mistral-tiny)
MISTRAL_MODEL=mistral-tiny

# ===========================================
# Server Configuration
# ===========================================
# Port du serveur (par défaut : 3000)
PORT=3000

# URL de base du serveur (pour les webhooks)
# Exemple : https://ton-serveur.com ou http://localhost:3000 (pour les tests)
BASE_URL=http://localhost:3000

# ===========================================
# Bot Configuration
# ===========================================
# Nom du bot (pour les réponses)
BOT_NAME=Vibe Bot

# Préfixe pour les commandes (ex: @vibe)
BOT_PREFIX=@vibe

# Liste des dépôts autorisés (séparés par des virgules)
# Exemple : polmichel/poker_tool,polmichel/autre-depot
ALLOWED_REPOS=polmichel/poker_tool

# Liste des utilisateurs autorisés (optionnel, séparés par des virgules)
# Exemple : polmichel,autre-utilisateur
# ALLOWED_USERS=polmichel

# ===========================================
# Logging Configuration
# ===========================================
# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info
