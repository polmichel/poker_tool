# ===========================================
# Configuration pour le développement LOCAL
# ===========================================
# Ces variables sont utilisées UNIQUEMENT pour les tests locaux.
# En production (GitHub Actions, Railway, Render, etc.), utilise les secrets GitHub.

# ===========================================
# GitHub App Configuration
# ===========================================
# Utilise les mêmes noms que tes secrets GitHub pour faciliter la transition

# ID de l'application GitHub (même valeur que POKER_TOOL_APP_ID dans les secrets)
POKER_TOOL_APP_ID=your_github_app_id_here

# Clé privée de l'application (format PEM, même valeur que POKER_TOOL_PRIVATE_KEY)
# Copie TOUT le contenu du fichier .pem téléchargé depuis GitHub
POKER_TOOL_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"

# Secret du webhook (même valeur que POKER_TOOL_APP_SECRET_KEY dans les secrets)
POKER_TOOL_APP_SECRET_KEY=your_webhook_secret_here

# ===========================================
# Mistral AI Configuration
# ===========================================
# Clé API Mistral (même valeur que MISTRAL_API_KEY dans les secrets)
MISTRAL_API_KEY=your_mistral_api_key_here

# Modèle à utiliser (optionnel)
MISTRAL_MODEL=mistral-tiny

# ===========================================
# Server Configuration (pour les tests locaux)
# ===========================================
PORT=3000
BASE_URL=http://localhost:3000

# ===========================================
# Bot Configuration
# ===========================================
BOT_NAME=Vibe Bot
BOT_PREFIX=@vibe
ALLOWED_REPOS=polmichel/poker_tool
# ALLOWED_USERS=polmichel,autre-utilisateur

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=debug
