# Exemple de fichier .env pour le backend

# Clé secrète pour Flask (générez-en une aléatoire)
SECRET_KEY=your_secret_key_here

# Clé secrète pour JWT (générez-en une aléatoire)
JWT_SECRET_KEY=your_jwt_secret_key_here

# URL de la base de données (SQLite par défaut)
DATABASE_URL=sqlite:///poker_tool.db

# Configuration CORS (pour le développement)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
